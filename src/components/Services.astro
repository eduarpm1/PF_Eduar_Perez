---
import Card from "./Card.astro";

const services = [
  {
    title: "Rollos Especiales",
    description:
      "Maki y uramaki elaborados a mano, con combinaciones de pescado fresco, aguacate y salsas de la casa.",
    image: "img/tarjeta 1.jpg",
    icon: "🍣",
  },
  {
    title: "Selección de Nigiri",
    description:
      "Piezas clásicas de nigiri, cortadas al momento sobre arroz sazonado con vinagre de arroz tradicional.",
    image:
      "img/tarjeta 2.jpg",
    icon: "🍱",
  },
  {
    title: "Ramen de la Casa",
    description:
      "Caldo cocinado a fuego lento durante horas, con fideos frescos y toppings preparados a diario.",
    image:
      "img/tarjeta 3.jpg",
    icon: "🍜",
  },
  {
    title: "Sashimi Premium",
    description:
      "Cortes finos de pescado de la más alta calidad, servidos en su punto justo de frescura.",
    image:
      "img/tarjeta 4.webp",
    icon: "🐟",
  },
    {
    title: "Tempura Crujiente",
    description:
      "Vegetales y mariscos rebozados con una técnica ligera, que conserva su textura y sabor.",
    image:
      "img/tarjeta 5.jpg",
    icon: "🍤",
  },
   {
    title: "Sake y Bebidas",
    description:
      "Selección de sakes importados y bebidas tradicionales, elegidas para acompañar tu comida.",
    image:
      "img/tarjeta 6.jpg",
    icon: "🍶",
  },
  
];
---

<section id="servicios" class="services">
  <div class="container">
    <div class="section-header">
      <h2>Nuestros Servicios</h2>
      <p>Descubre todas las experiencias que tenemos preparadas para ti</p>
    </div>

    <div class="cards-grid">
      {
        services.map((service) => (
          <Card
            title={service.title}
            description={service.description}
            image={service.image}
            icon={service.icon}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-gray-light);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-dark);
  }

  .section-header p {
    font-size: 1.1rem;
    color: #6b7280;
    max-width: 500px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 1.75rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style>
